---
import { getCollection, render, type CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/blog.css";

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection("news", ({ data }) => data.draft !== true);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^.]+$/, "") },
    props: { entry },
  }));
};

type Props = { entry: CollectionEntry<"news"> };

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} activePath="/aktualnosci">
  <main class="blog-post">
    <a class="blog-back" href="/aktualnosci/">Powrot do aktualnosci</a>
    <article>
      <h1>{entry.data.title}</h1>
      <p>{entry.data.description}</p>
      <time datetime={entry.data.date.toISOString()}>
        {entry.data.date.toLocaleDateString("pl-PL")}
      </time>
      <Content />
    </article>
  </main>
</BaseLayout>
