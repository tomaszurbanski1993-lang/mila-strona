---
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("news", ({ data }) => data.draft !== true);
  return entries.map((entry) => ({ params: { slug: entry.slug } }));
}

const { slug } = Astro.params;
if (!slug) {
  throw new Error("Missing slug parameter for news entry.");
}

const entry = await getEntry("news", slug);
if (!entry || entry.data.draft === true) {
  return Astro.redirect("/aktualnosci/");
}

const { Content } = await render(entry);
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{entry.data.title}</title>
  </head>
  <body>
    <main>
      <p><a href="/aktualnosci/">Powrot do aktualnosci</a></p>
      <article>
        <h1>{entry.data.title}</h1>
        <p>{entry.data.description}</p>
        <time datetime={entry.data.date.toISOString()}>
          {entry.data.date.toLocaleDateString("pl-PL")}
        </time>
        <Content />
      </article>
    </main>
  </body>
</html>
