---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/blog.css";

const entries = await getCollection("news", ({ data }) => data.draft !== true);
const items: CollectionEntry<"news">[] = entries.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const toSlug = (id: string): string => id.replace(/\.[^.]+$/, "");
---

<BaseLayout title="Aktualności" activePath="/aktualnosci">
  <main class="blog-list">
    <h1>Aktualnosci</h1>
    {
      items.length === 0 ? (
        <p class="blog-empty">Brak aktualnosci.</p>
      ) : (
        <ul>
          {items.map((item) => (
            <li>
              <a href={`/aktualnosci/${toSlug(item.id)}/`}>{item.data.title}</a>
              <p>{item.data.description}</p>
              <time datetime={item.data.date.toISOString()}>
                {item.data.date.toLocaleDateString("pl-PL")}
              </time>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
