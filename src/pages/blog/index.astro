---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/blog.css";

const entries = await getCollection("blog", ({ data }) => data.draft !== true);
const posts: CollectionEntry<"blog">[] = entries.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
//regex do obciecia .md z końcówki url
const toSlug = (id: string): string => id.replace(/\.[^.]+$/, "");
---

<BaseLayout title="Blog" activePath="/blog">
  <main class="blog-list">
    <h1>Blog</h1>
    {
      posts.length === 0 ? (
        <p class="blog-empty">Brak wpisow.</p>
      ) : (
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/blog/${toSlug(post.id)}/`}>{post.data.title}</a>
              <p>{post.data.description}</p>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("pl-PL")}
              </time>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
